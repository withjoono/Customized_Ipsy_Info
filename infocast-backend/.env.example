# ──────────────────────────────────────────────────────────────
# Infocast Backend — 환경변수 예시
# 실제 값은 .env 에. 생태계 공유 값(AUTH_*)은 절대 변경 금지.
# ──────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4012

# DB — 공유 Cloud SQL PostgreSQL, 스키마 격리(infocast)
# schema 파라미터로 본 앱 스키마 고정. 외부 스키마는 읽기전용 계정으로 별도 접근.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/geobukschool_dev?schema=infocast"
# (선택) 생태계 변화 감지용 읽기전용 계정
DATABASE_READONLY_URL="postgresql://RO_USER:RO_PASSWORD@localhost:5432/geobukschool_dev"

# 인증 (Hub SSO) — 생태계 공유 값. Base64 secret.
AUTH_JWT_SECRET="<생태계-공유-BASE64-SECRET>"
# 서버-서버 호출용 서비스 시크릿 + 식별자
AUTH_SERVICE_SECRET="<서비스-시크릿>"
SERVICE_ID=infocast

# Hub
HUB_BASE_URL=http://localhost:4000
HUB_INTERNAL_BASE_URL=http://localhost:4000

# Frontend (CORS / SSO redirect 허용)
FRONTEND_URL=http://localhost:3012

# 관리자 화이트리스트 (JWT role=admin 이 아니어도 허용할 이메일, 콤마구분)
ADMIN_EMAILS=withjoono@gmail.com

# Vertex AI (Phase 4 임베딩)
GCP_PROJECT_ID=ts-back-nest-479305
VERTEX_LOCATION=asia-northeast3
VERTEX_EMBEDDING_MODEL=text-embedding-004

# 알림 채널 (Phase 3 — 필요 시 채움)
KAKAO_ALIMTALK_KEY=
SMS_PROVIDER_KEY=
FCM_SERVICE_ACCOUNT=
EMAIL_SMTP_URL=
